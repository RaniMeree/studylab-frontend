# Backend API URL — set this to your deployed backend URL (Railway, Render, etc.)
# Leave blank / unset for local development (falls back to localhost:8000)
EXPO_PUBLIC_API_URL=https://studylab-c6bs.onrender.com

# RevenueCat public SDK keys — safe to ship in the app (these are NOT secret keys).
# Get them from: https://app.revenuecat.com → Project Settings → API Keys

# iOS key (starts with appl_) — from the App Store app you added in RevenueCat
EXPO_PUBLIC_RC_IOS_KEY=appl_REPLACE_ME

# Android key (starts with goog_) — from the Google Play app you added in RevenueCat
EXPO_PUBLIC_RC_ANDROID_KEY=goog_REPLACE_ME

# Web Billing key (starts with rcb_) — from the Stripe/Web app you added in RevenueCat
# Requires: RevenueCat → Apps → + New App → Stripe → connect your Stripe account
EXPO_PUBLIC_RC_WEB_KEY=rcb_REPLACE_ME
