{
  "expo": {
    "name": "PDF to Audio",
    "slug": "pdf-to-audio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mystudylab.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to photograph pages and convert them to audio.",
        "NSMicrophoneUsageDescription": "Not used by this app.",
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mystudylab.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Used to photograph pages and convert them to audio."
        }
      ],
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "888f0e97-634a-452a-9de9-79cda5be6b47"
      }
    },
    "owner": "wolfwolf"
  }
}
